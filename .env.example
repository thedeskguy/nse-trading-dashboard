# Copy this file to .env and fill in your values
# Never commit .env

# Angel One SmartAPI (for live options chain — NIFTY, BANKNIFTY)
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_MPIN=
ANGEL_TOTP_SECRET=

# Supabase (backend JWT verification — used by FastAPI)
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Set to 1 ONLY for local dev when SUPABASE_URL is intentionally absent.
# Never set in production — it bypasses JWT signature verification.
ALLOW_UNVERIFIED_JWT=0

# Razorpay (payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_MONTHLY=
RAZORPAY_PLAN_ID_ANNUAL=

# OpenAI / Anthropic (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
